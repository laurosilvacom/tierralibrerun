# Core application
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_SITE_VERIFICATION=

# Site branding (see src/lib/site.ts for defaults)
NEXT_PUBLIC_SITE_NAME=My Trail Community
NEXT_PUBLIC_SITE_TAGLINE=Advancing Access in Trail Running
NEXT_PUBLIC_SITE_DESCRIPTION=A trail running community building authentic connections through nature.
NEXT_PUBLIC_CONTACT_EMAIL=team@example.com
NEXT_PUBLIC_TAX_ID=
NEXT_PUBLIC_DONATION_URL=

# Default Open Graph / social share image (upload your own to Sanity and paste the CDN URL here)
# Example: https://cdn.sanity.io/images/YOUR_PROJECT_ID/production/YOUR_HASH-1200x630.jpg
NEXT_PUBLIC_DEFAULT_OG_IMAGE=

# Social links
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_STRAVA_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TWITTER_HANDLE=

# Email — transactional confirmations only (e.g. application acceptance)
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_REPLY_TO_ADDRESS=team@example.com
RESEND_API_KEY=re_your_resend_api_key

# Team / signatures
SITE_FOUNDER_NAME=
SITE_PROGRAM_LEAD_NAME=
SITE_PROGRAM_LEAD_EMAIL=

# Admin access (comma-separated email addresses, server-side only)
ADMIN_EMAILS=admin@example.com

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/?auth=sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/?auth=sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/new-user
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/new-user
# Leave Clerk force-redirect vars unset here. The app sets per-flow force redirects
# in code so athlete fund application intent survives sign-up.

# Convex — DO NOT set these manually.
#
# Run `pnpm convex:dev` once to provision your personal dev deployment. The Convex
# CLI will write CONVEX_DEPLOYMENT and NEXT_PUBLIC_CONVEX_URL into your .env.local
# automatically, pointing at your dev environment (not production).
#
# Production values live in convex.json and are deployed with `pnpm convex:deploy`.

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-01
SANITY_API_TOKEN=skt_your_sanity_api_token
